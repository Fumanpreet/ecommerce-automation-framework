<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="Automation Suite" parallel="tests" thread-count="3">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="UI Tests">
        <packages>
            <package name="ui"/>
        </packages>
    </test>

    <test name="API Tests">
        <packages>
            <package name="api"/>
        </packages>
    </test>

    <test name="E2E Tests">
        <packages>
            <package name="e2e"/>
        </packages>
    </test>

</suite>